  },
  "files": [
    "dist",
    "skills"
  ],
  "dependencies": {
    "commander": "^13.0.0",
    "fontoxpath": "^3.34.0",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
